<!DOCTYPE html>
<html lang="{{locale}}" dir="{{#if isRTL}}rtl{{else}}ltr{{/if}}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{basics.fullName}} — {{basics.title}}</title>
<meta name="description" content="{{basics.title}}{{#if basics.location}} based in {{basics.location}}{{/if}}.{{#if basics.subtitle}} {{basics.subtitle}}{{/if}}">
<meta name="theme-color" content="#F8FAFC">
<meta property="og:title" content="{{basics.fullName}} | {{basics.title}}">
<meta property="og:description" content="{{#if basics.subtitle}}{{basics.subtitle}}{{else}}{{basics.title}}{{#if basics.location}} based in {{basics.location}}{{/if}}{{/if}}">
<meta property="og:type" content="website">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
{{#if customization.fontFamily}}
<link href="https://fonts.googleapis.com/css2?family={{customization.fontFamily}}:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{{else}}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{{/if}}
<style>
/* ══════════════════════════════════════════════════════
   THE INSTITUTIONAL PROSPECTUS
   Corporate Portfolio — HR-First Design
   Purpose: Get the candidate hired. Period.
   ══════════════════════════════════════════════════════ */

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
    --navy: #0F172A;
    --navy-deep: #0B1120;
    --blue: #1E3A8A;
    --blue-soft: #3B82F6;
    --gold: #A16207;
    --gold-warm: #CA8A04;
    --gold-light: rgba(161, 98, 7, 0.07);
    --gold-border: rgba(161, 98, 7, 0.18);

    --bg: #F8FAFC;
    --bg-warm: #F1F5F9;
    --bg-white: #FFFFFF;
    --text: #020617;
    --text-sub: #475569;
    --text-dim: #94A3B8;
    --text-on-dark: #E2E8F0;
    --text-on-dark-dim: #94A3B8;
    --border: #E2E8F0;
    --border-strong: #CBD5E1;

    --font-head: 'Playfair Display', Georgia, serif;
    --font-body: 'Inter', system-ui, sans-serif;

    --r: 10px;
    --r-sm: 6px;
    --shadow-sm: 0 1px 2px rgba(15,23,42,0.04);
    --shadow-md: 0 4px 12px rgba(15,23,42,0.06);
    --shadow-lg: 0 8px 30px rgba(15,23,42,0.08);
    --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

html { scroll-behavior: smooth; font-size: 16px; }
body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
}
a { text-decoration: none; color: inherit; }

/* ═══ SCROLL PROGRESS ═══ */
.scroll-bar {
    position: fixed; top: 0; left: 0; height: 2px; z-index: 10001;
    background: linear-gradient(90deg, var(--gold), var(--gold-warm));
    width: 0%;
}

/* ═══ NAV ═══ */
.nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    padding: 18px 48px;
    display: flex; justify-content: space-between; align-items: center;
    background: rgba(248,250,252,0.88);
    backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid transparent;
    transition: all 250ms var(--ease);
}
.nav.scrolled {
    padding: 12px 48px;
    border-bottom-color: var(--border);
    box-shadow: var(--shadow-sm);
}
.nav-brand {
    font-family: var(--font-head); font-weight: 600; font-size: 1.05rem;
    color: var(--navy); letter-spacing: -0.02em;
}
.nav-brand span { color: var(--gold); font-weight: 400; }
.nav-links { display: flex; gap: 28px; align-items: center; }
.nav-links a {
    color: var(--text-sub); font-size: 0.78rem; font-weight: 500;
    letter-spacing: 0.05em; text-transform: uppercase;
    transition: color 200ms; cursor: pointer;
}
.nav-links a:hover { color: var(--navy); }
.nav-cta {
    color: var(--gold) !important;
    border: 1.5px solid var(--gold-border);
    padding: 7px 20px; border-radius: 100px;
    transition: all 200ms !important;
}
.nav-cta:hover { background: var(--gold-light) !important; }
.nav-toggle { display: none; background: none; border: none; cursor: pointer; padding: 4px; }
.nav-toggle svg { width: 22px; height: 22px; color: var(--navy); }

/* ═══ LAYOUT ═══ */
.section { padding: 80px 0; }
.container { max-width: 1100px; margin: 0 auto; padding: 0 36px; }

.section-label {
    font-size: 0.68rem; font-weight: 600;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--gold);
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 14px;
}
.section-label::before {
    content: ''; width: 24px; height: 1.5px; background: var(--gold);
}
.section-title {
    font-family: var(--font-head);
    font-size: clamp(1.6rem, 2.8vw, 2.2rem);
    font-weight: 500; color: var(--navy);
    line-height: 1.25; letter-spacing: -0.02em;
    margin-bottom: 40px;
}
.section-title em { font-style: italic; color: var(--gold); font-weight: 400; }

.gold-rule {
    width: 100%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-border) 20%, var(--gold-border) 80%, transparent);
}

/* ══════════════════════════════════════════════════════
   1. HERO — The 6-Second Scan Zone
   Everything HR needs: name, title, contact, credentials count
   ══════════════════════════════════════════════════════ */

/* Hero Keyframes */
@keyframes heroSlideLeft {
    from { opacity: 0; transform: translateX(-60px); }
    to { opacity: 1; transform: translateX(0); }
}
@keyframes heroSlideRight {
    from { opacity: 0; transform: translateX(60px) scale(0.95); }
    to { opacity: 1; transform: translateX(0) scale(1); }
}
@keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
}
@keyframes heroNameReveal {
    0% { opacity: 0; transform: translateY(40px) skewY(3deg); }
    60% { opacity: 1; transform: translateY(-4px) skewY(0deg); }
    100% { opacity: 1; transform: translateY(0) skewY(0deg); }
}
@keyframes metricPop {
    0% { opacity: 0; transform: scale(0.7) translateY(20px); }
    70% { transform: scale(1.05) translateY(-2px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
}
@keyframes navyPanelSlide {
    from { clip-path: polygon(100% 0, 100% 0, 100% 100%, 100% 100%); }
    to { clip-path: polygon(18% 0, 100% 0, 100% 100%, 0% 100%); }
}
@keyframes goldLineDraw {
    from { width: 0; }
    to { width: 100%; }
}
@keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
}
@keyframes floatSubtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
}
@keyframes pulseGlow {
    0%, 100% { box-shadow: 0 8px 30px rgba(15,23,42,0.08); }
    50% { box-shadow: 0 12px 40px rgba(15,23,42,0.15), 0 0 60px rgba(161,98,7,0.08); }
}

.hero {
    min-height: 100vh; display: flex; align-items: center;
    position: relative; padding-top: 80px; overflow: hidden;
}
.hero::before {
    content: ''; position: absolute; top: 0; right: 0;
    width: 42%; height: 100%;
    background: var(--navy);
    clip-path: polygon(18% 0, 100% 0, 100% 100%, 0% 100%);
    animation: navyPanelSlide 1s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both;
    z-index: 0;
}

.hero-grid {
    display: grid; grid-template-columns: 1fr 360px;
    gap: 72px; align-items: center;
    position: relative; z-index: 1;
}

.hero-content {
    padding: 32px 0;
    animation: heroSlideLeft 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.4s both;
}

.hero-location {
    font-size: 0.76rem; font-weight: 500; color: var(--text-dim);
    display: flex; align-items: center; gap: 6px;
    letter-spacing: 0.04em; text-transform: uppercase;
    margin-bottom: 16px;
    animation: heroFadeUp 0.7s var(--ease) 0.6s both;
}
.hero-location svg { width: 13px; height: 13px; }

.hero-name {
    font-family: var(--font-head);
    font-size: clamp(2.6rem, 5vw, 3.8rem);
    font-weight: 700; line-height: 1.05;
    letter-spacing: -0.03em; color: var(--navy);
    margin-bottom: 8px;
    animation: heroNameReveal 1s cubic-bezier(0.22, 1, 0.36, 1) 0.5s both;
}

.hero-title {
    font-family: var(--font-head);
    font-size: 1.2rem; font-weight: 400; font-style: italic;
    color: var(--text-sub); margin-bottom: 24px;
    animation: heroFadeUp 0.8s var(--ease) 0.8s both;
}

/* Contact row — visible without scrolling */
.hero-contact {
    display: flex; gap: 20px; flex-wrap: wrap;
    margin-bottom: 40px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--border);
    animation: heroFadeUp 0.8s var(--ease) 1s both;
}
.hero-contact a, .hero-contact span {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.82rem; color: var(--text-sub); font-weight: 500;
    transition: color 200ms, transform 200ms;
}
.hero-contact a:hover { color: var(--gold); transform: translateY(-2px); }
.hero-contact svg { width: 15px; height: 15px; color: var(--gold); flex-shrink: 0; }

/* Metrics — annual report KPI strip */
.hero-metrics {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border-top: 2px solid var(--navy);
    position: relative;
}
.hero-metrics::before {
    content: ''; position: absolute; top: -2px; left: 0;
    height: 2px; background: var(--navy);
    animation: goldLineDraw 0.8s var(--ease) 1.2s both;
}
.metric {
    padding: 18px 0; text-align: left;
    border-right: 1px solid var(--border);
    padding-right: 16px;
    animation: metricPop 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    transition: transform 300ms var(--ease);
}
.metric:nth-child(1) { animation-delay: 1.3s; }
.metric:nth-child(2) { animation-delay: 1.45s; }
.metric:nth-child(3) { animation-delay: 1.6s; }
.metric:nth-child(4) { animation-delay: 1.75s; }
.metric:hover { transform: translateY(-3px); }
.metric:last-child { border-right: none; }
.metric:not(:first-child) { padding-left: 16px; }
.metric-val {
    font-family: var(--font-head);
    font-size: 1.7rem; font-weight: 700;
    color: var(--navy); line-height: 1;
}
.metric-label {
    font-size: 0.65rem; color: var(--text-dim);
    margin-top: 4px; letter-spacing: 0.06em;
    text-transform: uppercase; font-weight: 500;
}

/* Portrait */
.hero-portrait-wrap {
    position: relative; z-index: 2;
    animation: heroSlideRight 1s cubic-bezier(0.22, 1, 0.36, 1) 0.6s both;
}
.hero-portrait {
    width: 100%; aspect-ratio: 3/4;
    border-radius: var(--r);
    background: linear-gradient(180deg, var(--bg-warm), var(--border));
    border: 1px solid rgba(255,255,255,0.25);
    overflow: hidden; box-shadow: var(--shadow-lg);
    display: flex; align-items: center; justify-content: center;
    position: relative;
    animation: pulseGlow 4s ease-in-out 2.5s infinite, floatSubtle 6s ease-in-out 2.5s infinite;
}
.hero-portrait-ph svg { width: 80px; height: 80px; color: var(--text-dim); opacity: 0.25; }
.hero-portrait-tag {
    position: absolute; bottom: 14px; left: 14px; right: 14px;
    text-align: center; font-size: 0.65rem; color: var(--text-dim);
    letter-spacing: 0.1em; text-transform: uppercase; font-weight: 500;
    background: rgba(248,250,252,0.85); backdrop-filter: blur(6px);
    padding: 6px; border-radius: var(--r-sm);
}

/* ══════════════════════════════════════════════════════
   2. CREDENTIALS BAR — Trust badges, no heading
   The wall of diplomas behind the desk
   ══════════════════════════════════════════════════════ */
.credentials {
    background: var(--bg-warm);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 36px 0;
}
.credentials-strip {
    display: flex; justify-content: center;
    gap: 40px; flex-wrap: wrap;
}
.cred-badge {
    text-align: center; min-width: 100px;
}
.cred-acronym {
    font-family: var(--font-head);
    font-size: 1.3rem; font-weight: 700;
    color: var(--gold); letter-spacing: -0.01em;
    line-height: 1.2;
}
.cred-issuer {
    font-size: 0.62rem; color: var(--text-dim);
    letter-spacing: 0.04em; margin-top: 2px;
    font-weight: 500;
}

/* ══════════════════════════════════════════════════════
   3. VALUE PROPOSITION — The clarity test
   ══════════════════════════════════════════════════════ */
.value-prop { background: var(--bg-white); }
.value-prop-inner {
    max-width: 720px; margin: 0 auto; text-align: center;
}
.value-prop-text {
    font-size: 1.1rem; color: var(--text-sub);
    line-height: 1.9;
}
.value-prop-text strong { color: var(--navy); font-weight: 600; }

/* ══════════════════════════════════════════════════════
   4. CAREER TRAJECTORY — Company names sell
   ══════════════════════════════════════════════════════ */
.career { background: var(--bg); }

.timeline {
    display: flex; flex-direction: column;
    border-left: 2px solid var(--border);
    margin-left: 16px;
}
.tl-item {
    position: relative;
    padding: 0 0 40px 40px;
}
.tl-item:last-child { padding-bottom: 0; }
.tl-item::before {
    content: ''; position: absolute; left: -7px; top: 8px;
    width: 12px; height: 12px; border-radius: 50%;
    background: var(--bg); border: 2.5px solid var(--gold);
    z-index: 1;
}
.tl-card {
    padding: 24px 28px;
    background: var(--bg-white);
    border: 1px solid var(--border);
    border-radius: var(--r);
    box-shadow: var(--shadow-sm);
}

.tl-top {
    display: flex; justify-content: space-between;
    align-items: flex-start; gap: 12px;
    margin-bottom: 6px;
}
.tl-company {
    font-family: var(--font-head);
    font-size: 1.1rem; font-weight: 700;
    color: var(--navy); letter-spacing: -0.01em;
}
.tl-period-wrap {
    display: flex; align-items: center; gap: 8px;
    flex-shrink: 0;
}
.tl-period {
    font-size: 0.72rem; font-weight: 600; color: var(--gold);
    padding: 3px 10px; border-radius: 100px;
    background: var(--gold-light); letter-spacing: 0.02em;
    white-space: nowrap;
}
.tl-duration {
    font-size: 0.68rem; color: var(--text-dim);
    font-weight: 500; white-space: nowrap;
}
.tl-role {
    font-size: 0.88rem; color: var(--text-sub);
    font-weight: 500; margin-bottom: 14px;
}

.tl-results { display: flex; flex-direction: column; gap: 7px; }
.tl-result {
    font-size: 0.82rem; color: var(--text-sub);
    padding-left: 18px; position: relative; line-height: 1.6;
}
.tl-result::before {
    content: ''; position: absolute; left: 0; top: 9px;
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--gold); opacity: 0.7;
}

/* ══════════════════════════════════════════════════════
   5. IMPACT STORIES — STAR format, anonymized
   ══════════════════════════════════════════════════════ */
.impact { background: var(--bg-white); }

.impact-grid {
    display: grid; grid-template-columns: 1fr;
    gap: 20px;
}
.impact-grid-2col {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 20px; margin-top: 20px;
}

.impact-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--r);
    padding: 28px 32px;
    position: relative;
}
.impact-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0;
    height: 2px; background: var(--border); border-radius: var(--r) var(--r) 0 0;
}
.impact-card.primary::before {
    background: linear-gradient(90deg, var(--gold), var(--gold-warm));
}

.impact-situation {
    font-size: 0.72rem; font-weight: 600; color: var(--text-dim);
    letter-spacing: 0.08em; text-transform: uppercase;
    margin-bottom: 10px;
}

.impact-card h3 {
    font-family: var(--font-head);
    font-size: 1.05rem; font-weight: 600;
    color: var(--navy); margin-bottom: 10px;
}
.impact-card > p {
    font-size: 0.85rem; color: var(--text-sub);
    line-height: 1.7; margin-bottom: 18px;
}

.impact-kpis {
    display: flex; gap: 24px;
    padding: 14px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 14px;
}
.kpi-val {
    font-family: var(--font-head);
    font-size: 1.25rem; font-weight: 700;
    color: var(--navy); line-height: 1;
}
.kpi-lbl {
    font-size: 0.62rem; color: var(--text-dim);
    margin-top: 3px; text-transform: uppercase;
    letter-spacing: 0.04em; font-weight: 500;
}
.impact-tools { display: flex; flex-wrap: wrap; gap: 5px; }
.tool-tag {
    padding: 3px 9px; border-radius: 100px;
    background: var(--bg-white); border: 1px solid var(--border);
    font-size: 0.68rem; color: var(--text-sub); font-weight: 500;
}

/* ══════════════════════════════════════════════════════
   6. COMPETENCIES — Tags, not bars
   ══════════════════════════════════════════════════════ */
.competencies { background: var(--bg); }

.comp-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}
.comp-group {
    padding: 28px;
    background: var(--bg-white);
    border: 1px solid var(--border);
    border-radius: var(--r);
}
.comp-icon {
    width: 40px; height: 40px; border-radius: 8px;
    background: var(--navy); display: flex;
    align-items: center; justify-content: center;
    margin-bottom: 16px;
}
.comp-icon svg { width: 20px; height: 20px; color: #fff; }
.comp-group h3 {
    font-family: var(--font-head);
    font-size: 0.95rem; font-weight: 600;
    color: var(--navy); margin-bottom: 16px;
}
.comp-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.comp-tag {
    padding: 5px 14px; border-radius: 100px;
    background: var(--bg);
    border: 1px solid var(--border);
    font-size: 0.76rem; color: var(--text-sub);
    font-weight: 500; transition: border-color 200ms, color 200ms;
}
.comp-tag:hover {
    border-color: var(--gold-border); color: var(--gold);
}

/* ══════════════════════════════════════════════════════
   7. EDUCATION — Degrees only
   ══════════════════════════════════════════════════════ */
.education { background: var(--bg-white); }

.edu-list {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 20px;
}
.edu-card {
    padding: 22px 24px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--r);
}
.edu-year {
    font-family: var(--font-head);
    font-size: 0.8rem; color: var(--gold);
    font-style: italic; font-weight: 500;
    margin-bottom: 6px;
}
.edu-card h3 {
    font-family: var(--font-head);
    font-size: 0.95rem; font-weight: 600;
    color: var(--navy); margin-bottom: 3px;
}
.edu-card .inst {
    font-size: 0.8rem; color: var(--text-sub); font-weight: 500;
}

/* ══════════════════════════════════════════════════════
   8. PROFESSIONAL PROFILE — Languages, Affiliations, Dev
   ══════════════════════════════════════════════════════ */
.profile { background: var(--bg); }

.profile-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr;
    gap: 32px;
}
.profile-col {}
.profile-heading {
    font-size: 0.68rem; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--text-dim); margin-bottom: 14px;
    padding-bottom: 10px; border-bottom: 1px solid var(--border);
}

/* Languages */
.lang-list { display: flex; flex-direction: column; gap: 8px; }
.lang-item {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px;
    background: var(--bg-white); border: 1px solid var(--border);
    border-radius: var(--r-sm);
}
.lang-item svg { width: 16px; height: 16px; color: var(--navy); margin-right: 8px; }
.lang-name { font-size: 0.85rem; font-weight: 600; color: var(--navy); display: flex; align-items: center; }
.lang-level {
    font-size: 0.65rem; color: var(--text-dim);
    background: var(--bg); padding: 2px 10px;
    border-radius: 100px; font-weight: 600;
}

/* Affiliations & Development */
.profile-list { display: flex; flex-direction: column; gap: 10px; }
.profile-item {
    font-size: 0.82rem; color: var(--text-sub);
    padding-left: 14px; position: relative;
    line-height: 1.5;
}
.profile-item::before {
    content: ''; position: absolute; left: 0; top: 8px;
    width: 4px; height: 4px; border-radius: 50%;
    background: var(--gold);
}
.profile-item strong { color: var(--navy); font-weight: 600; }
.profile-item .meta {
    font-size: 0.72rem; color: var(--text-dim);
    display: block; margin-top: 1px;
}

/* ══════════════════════════════════════════════════════
   9. ENDORSEMENTS — Social proof for desk workers
   ══════════════════════════════════════════════════════ */
.endorsements {
    background: var(--bg-warm);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
}

.endorsement-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}
.endorsement-card {
    background: var(--bg-white);
    border: 1px solid var(--border);
    border-radius: var(--r);
    padding: 28px 24px;
}
.endorsement-quote-mark {
    font-family: var(--font-head);
    font-size: 3rem; line-height: 1;
    color: var(--gold); opacity: 0.5;
    margin-bottom: 8px;
}
.endorsement-text {
    font-size: 0.88rem; color: var(--text-sub);
    line-height: 1.75; font-style: italic;
    margin-bottom: 18px;
}
.endorsement-author {
    border-top: 1px solid var(--border);
    padding-top: 14px;
}
.endorsement-name {
    font-size: 0.82rem; font-weight: 600; color: var(--navy);
}
.endorsement-role {
    font-size: 0.72rem; color: var(--text-dim);
}

/* ══════════════════════════════════════════════════════
   10. CONTACT — Navy section, clear CTA
   ══════════════════════════════════════════════════════ */
.contact { background: var(--navy); color: var(--text-on-dark); }
.contact .section-label { color: var(--gold-warm); }
.contact .section-label::before { background: var(--gold-warm); }
.contact .section-title { color: #fff; }
.contact .section-title em { color: var(--gold-warm); }

.contact-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1px; background: rgba(255,255,255,0.06);
    border-radius: var(--r); overflow: hidden;
}
.contact-cell {
    background: rgba(15,23,42,0.5);
    padding: 28px 20px; text-align: center;
    transition: background 200ms;
}
.contact-cell:hover { background: rgba(30,58,138,0.25); }
.contact-cell svg { width: 22px; height: 22px; color: var(--gold-warm); margin: 0 auto 12px; display: block; }
.contact-cell h4 {
    font-family: var(--font-head);
    font-size: 0.8rem; font-weight: 600; color: #fff;
    margin-bottom: 4px;
}
.contact-cell p {
    font-size: 0.76rem; color: var(--text-on-dark-dim);
    word-break: break-all;
}

/* ═══ PDF BUTTON ═══ */
.pdf-btn {
    position: fixed; bottom: 24px; right: 24px; z-index: 999;
    padding: 10px 20px; border-radius: 8px;
    background: var(--navy); color: #fff;
    font-size: 0.78rem; font-weight: 600;
    font-family: var(--font-body);
    border: none; cursor: pointer;
    display: flex; align-items: center; gap: 7px;
    box-shadow: var(--shadow-lg);
    transition: all 200ms var(--ease);
}
.pdf-btn:hover { background: #1E293B; transform: translateY(-1px); }
.pdf-btn svg { width: 15px; height: 15px; }

/* ═══ FOOTER ═══ */
footer {
    padding: 36px 0; text-align: center;
    background: var(--navy-deep);
}
footer p { font-size: 0.7rem; color: var(--text-on-dark-dim); }
footer a { color: var(--gold-warm); border-bottom: 1px solid rgba(202,138,4,0.3); }
footer a:hover { border-color: var(--gold-warm); }

/* ═══ REVEAL ═══ */
.rv {
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.6s var(--ease), transform 0.6s var(--ease);
}
.rv.v { opacity: 1; transform: translateY(0); }
.rv-d1 { transition-delay: 0.06s; }
.rv-d2 { transition-delay: 0.12s; }
.rv-d3 { transition-delay: 0.18s; }
.rv-d4 { transition-delay: 0.24s; }

/* ═══ QR (print only) ═══ */
.qr-print { display: none; }

/* ══════════════════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════════════════ */
@media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr 300px; gap: 48px; }
    .hero::before { width: 38%; }
    .comp-grid { grid-template-columns: 1fr 1fr; }
    .endorsement-grid { grid-template-columns: 1fr 1fr; }
    .endorsement-grid > :last-child { grid-column: span 2; }
    .contact-grid { grid-template-columns: repeat(2, 1fr); }
    .profile-grid { grid-template-columns: 1fr 1fr; }
    .profile-grid > :last-child { grid-column: span 2; }
}

@media (max-width: 768px) {
    .nav { padding: 12px 20px; }
    .nav-links a:not(.nav-cta) { display: none; }
    .nav-toggle { display: block; }

    .hero { min-height: auto; padding: 100px 0 48px; }
    .hero::before { display: none; }
    .hero-grid { grid-template-columns: 1fr; gap: 24px; }
    .hero-portrait-wrap { display: none; }
    .hero-name { font-size: 2.2rem; }
    .hero-contact { gap: 12px; }
    .hero-metrics { grid-template-columns: repeat(2, 1fr); }
    .metric:nth-child(2) { border-right: none; }
    .metric:nth-child(3), .metric:nth-child(4) { border-top: 1px solid var(--border); }

    .credentials-strip { gap: 24px; }
    .cred-badge { min-width: 80px; }

    .tl-item { padding-left: 28px; }
    .tl-card { padding: 18px 20px; }
    .tl-top { flex-direction: column; gap: 6px; }

    .impact-grid-2col { grid-template-columns: 1fr; }
    .comp-grid { grid-template-columns: 1fr; }
    .edu-list { grid-template-columns: 1fr; }
    .endorsement-grid { grid-template-columns: 1fr; }
    .endorsement-grid > :last-child { grid-column: span 1; }
    .contact-grid { grid-template-columns: 1fr; }
    .profile-grid { grid-template-columns: 1fr; }
    .profile-grid > :last-child { grid-column: span 1; }

    .section { padding: 56px 0; }
    .container { padding: 0 20px; }
}

@media (max-width: 375px) {
    .hero-name { font-size: 1.9rem; }
    .hero-metrics { grid-template-columns: 1fr 1fr; }
    .hero-contact { flex-direction: column; gap: 8px; }
    .credentials-strip { gap: 16px; }
    .cred-acronym { font-size: 1.1rem; }
}

/* ══════════════════════════════════════════════════════
   PRINT / PDF
   ══════════════════════════════════════════════════════ */
@media print {
    @page { margin: 0.5in; size: A4; }
    * {
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
    }
    html, body { background: #fff !important; font-size: 10pt; }

    /* Hide non-print elements */
    .scroll-bar, .nav, .pdf-btn, .hero::before { display: none !important; }
    .rv { opacity: 1 !important; transform: none !important; transition: none !important; }

    /* ═══ PREVENT SECTION CUT-OFF ═══ */
    /* Cards, timeline entries, endorsements — never split across pages */
    .tl-card,
    .impact-card,
    .endorsement-card,
    .edu-card,
    .comp-group,
    .lang-item,
    .cert-card,
    .credential-card,
    .degree,
    .contact-grid,
    .hero-metrics,
    .value-prop-inner,
    .cred-badge {
        page-break-inside: avoid !important;
        break-inside: avoid !important;
    }

    /* Timeline items — keep each job entry together */
    .tl-item {
        page-break-inside: avoid !important;
        break-inside: avoid !important;
    }

    /* Section headers — never orphaned at bottom of page */
    .section-label,
    .section-title {
        page-break-after: avoid !important;
        break-after: avoid !important;
    }

    /* Keep section label + title + first content together */
    .section-label + .section-title {
        page-break-before: avoid !important;
        break-before: avoid !important;
    }

    /* Full sections — allow page breaks BETWEEN sections, not inside critical ones */
    .hero,
    .credentials,
    .value-prop {
        page-break-inside: avoid !important;
        break-inside: avoid !important;
    }

    /* Allow clean page breaks before major sections */
    .career,
    .impact,
    .competencies,
    .endorsements {
        page-break-before: auto;
        break-before: auto;
    }

    /* Endorsement row — keep all 3 together if possible */
    .endorsement-grid {
        page-break-inside: avoid !important;
        break-inside: avoid !important;
    }

    /* Profile grid — keep together */
    .profile-grid {
        page-break-inside: avoid !important;
        break-inside: avoid !important;
    }

    /* Education list — keep together */
    .edu-list {
        page-break-inside: avoid !important;
        break-inside: avoid !important;
    }

    /* Competency grid — keep together */
    .comp-grid {
        page-break-inside: avoid !important;
        break-inside: avoid !important;
    }

    /* ═══ SIZING FOR A4 ═══ */
    .hero { min-height: auto !important; padding: 0 0 12px !important; }
    .hero-grid { grid-template-columns: 1fr 130px !important; gap: 20px !important; }
    .hero-name { font-size: 20pt !important; }
    .hero-title { font-size: 10pt; }
    .hero-contact { margin-bottom: 10px; padding-bottom: 8px; font-size: 8pt; gap: 12px; }
    .hero-contact svg { width: 11px; height: 11px; }
    .hero-location { font-size: 7pt; margin-bottom: 8px; }
    .metric { padding: 6px 0; }
    .metric-val { font-size: 12pt; }
    .metric-label { font-size: 6pt; }

    .credentials { padding: 10px 0; }
    .credentials-strip { gap: 20px; }
    .cred-acronym { font-size: 10pt; }
    .cred-issuer { font-size: 6pt; }

    .section { padding: 14px 0 !important; }
    .section-title { font-size: 13pt !important; margin-bottom: 10px !important; }
    .section-label { font-size: 6pt; margin-bottom: 6px; }

    .value-prop-text { font-size: 9pt; line-height: 1.6; }

    /* Timeline compact */
    .timeline { margin-left: 8px; }
    .tl-item { padding-left: 24px; padding-bottom: 12px; }
    .tl-item::before { width: 8px; height: 8px; left: -5px; border-width: 2px; }
    .tl-card { box-shadow: none !important; padding: 8px 12px; border-color: var(--border); }
    .tl-company { font-size: 10pt; }
    .tl-role { font-size: 8pt; margin-bottom: 6px; }
    .tl-period { font-size: 6.5pt; padding: 2px 6px; }
    .tl-duration { font-size: 6pt; }
    .tl-result { font-size: 7.5pt; line-height: 1.5; padding-left: 12px; }
    .tl-result::before { width: 3px; height: 3px; top: 6px; }
    .tl-results { gap: 3px; }

    /* Impact cards compact */
    .impact-card { padding: 10px 14px; }
    .impact-situation { font-size: 6pt; margin-bottom: 4px; }
    .impact-card h3 { font-size: 9pt; margin-bottom: 4px; }
    .impact-card > p { font-size: 7.5pt; line-height: 1.5; margin-bottom: 8px; }
    .impact-kpis { padding: 6px 0; margin-bottom: 6px; gap: 16px; }
    .kpi-val { font-size: 10pt; }
    .kpi-lbl { font-size: 5.5pt; }
    .impact-grid-2col { margin-top: 10px; gap: 10px; }
    .tool-tag { font-size: 6pt; padding: 1px 6px; }

    /* Competencies compact */
    .comp-grid { gap: 10px; }
    .comp-group { padding: 10px 12px; }
    .comp-icon { width: 24px; height: 24px; border-radius: 4px; margin-bottom: 8px; }
    .comp-icon svg { width: 13px; height: 13px; }
    .comp-group h3 { font-size: 9pt; margin-bottom: 8px; }
    .comp-tag { font-size: 6.5pt; padding: 2px 8px; }
    .comp-tags { gap: 3px; }

    /* Education compact */
    .edu-list { gap: 8px; }
    .edu-card { padding: 8px 12px; }
    .edu-year { font-size: 7pt; margin-bottom: 2px; }
    .edu-card h3 { font-size: 8.5pt; margin-bottom: 1px; }
    .edu-card .inst { font-size: 7pt; }

    /* Profile compact */
    .profile-grid { gap: 16px; }
    .profile-heading { font-size: 6pt; margin-bottom: 8px; padding-bottom: 4px; }
    .lang-item { padding: 4px 8px; }
    .lang-name { font-size: 7.5pt; }
    .lang-name svg { width: 10px; height: 10px; }
    .lang-level { font-size: 5.5pt; padding: 1px 6px; }
    .profile-item { font-size: 7.5pt; padding-left: 10px; }
    .profile-item::before { width: 3px; height: 3px; top: 6px; }
    .profile-item .meta { font-size: 6.5pt; }

    /* Endorsements compact */
    .endorsements { border: none; background: var(--bg-warm) !important; }
    .endorsement-grid { gap: 10px; }
    .endorsement-card { padding: 10px 12px; }
    .endorsement-quote-mark { font-size: 1.5rem; margin-bottom: 2px; }
    .endorsement-text { font-size: 7.5pt; line-height: 1.5; margin-bottom: 8px; }
    .endorsement-name { font-size: 7pt; }
    .endorsement-role { font-size: 6.5pt; }
    .endorsement-author { padding-top: 6px; }

    /* Contact section */
    .contact {
        background: var(--navy) !important;
        color: #fff !important;
        page-break-inside: avoid !important;
        break-inside: avoid !important;
    }
    .contact .section-title { font-size: 11pt !important; }
    .contact-grid { gap: 0; }
    .contact-cell { padding: 12px 10px; }
    .contact-cell svg { width: 14px; height: 14px; margin-bottom: 4px; }
    .contact-cell h4 { font-size: 7pt; }
    .contact-cell p { font-size: 7pt; }

    /* Gold rules — thinner in print */
    .gold-rule { height: 0.5px; margin: 4px 0; }

    /* QR Code */
    .qr-print {
        display: block !important; text-align: center;
        padding: 16px 0;
        page-break-inside: avoid !important;
        break-inside: avoid !important;
    }
    .qr-print img {
        margin: 0 auto 4px; border: 3px solid #fff; border-radius: 4px;
    }
    .qr-print p { font-size: 7pt; color: var(--text-dim); }

    /* Footer */
    footer { padding: 8px 0; }
    footer p { font-size: 6pt; }
    footer a { border-bottom: none; }

    /* Container narrower for print margins */
    .container { padding: 0 0 !important; }
}

/* ═══ RTL ═══ */
[dir="rtl"] {
    .section-label { direction: rtl; }
    .section-label::before { display: none; }
    .section-label::after {
        content: ''; width: 24px; height: 1.5px; background: var(--gold);
    }
    .timeline { border-left: none; border-right: 2px solid var(--border); margin-left: 0; margin-right: 16px; }
    .tl-item { padding-left: 0; padding-right: 40px; }
    .tl-item::before { left: auto; right: -7px; }
    .tl-result { padding-left: 0; padding-right: 18px; }
    .tl-result::before { left: auto; right: 0; }
    .hero-content { text-align: right; }
    .hero-location { justify-content: flex-end; }
    .hero-contact { justify-content: flex-end; }
    .value-prop-inner { text-align: right; }
    .profile-item { padding-left: 0; padding-right: 14px; }
    .profile-item::before { left: auto; right: 0; }
    .nav-links { direction: ltr; }
}
</style>
{{#if customization}}
<style>
{{#if customization.primaryColor}}
:root {
    --navy: {{customization.primaryColor}};
    --navy-deep: {{customization.primaryColor}};
}
{{/if}}
{{#if customization.accentColor}}
:root {
    --gold: {{customization.accentColor}};
    --gold-warm: {{customization.accentColor}};
    --gold-light: {{customization.accentColor}}12;
    --gold-border: {{customization.accentColor}}2e;
}
{{/if}}
{{#if customization.fontFamily}}
:root {
    --font-head: '{{customization.fontFamily}}', Georgia, serif;
}
{{/if}}
</style>
{{/if}}
</head>
<body>

<!-- Scroll Progress -->
<div class="scroll-bar" id="scrollBar"></div>

<!-- Nav -->
<nav class="nav" id="nav">
    <a href="#" class="nav-brand">{{basics.fullName}} <span>Portfolio</span></a>
    <div class="nav-links">
        {{#if experience}}<a href="#career">Experience</a>{{/if}}
        {{#if projects}}<a href="#impact">Impact</a>{{/if}}
        {{#if certifications}}<a href="#credentials">Credentials</a>{{/if}}
        <a href="#contact" class="nav-cta">Contact</a>
    </div>
    <button class="nav-toggle" aria-label="Menu">
        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
    </button>
</nav>

<!-- 1. HERO -->
<section class="hero">
    <div class="container">
        <div class="hero-grid">
            <div class="hero-content">
                <div class="hero-location rv">
                    <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0 1 15 0Z"/></svg>
                    {{#if basics.location}}{{basics.location}}{{/if}}{{#if basics.nationality}} &middot; {{basics.nationality}}{{/if}}
                </div>

                <h1 class="hero-name rv rv-d1">{{basics.fullName}}</h1>
                <p class="hero-title rv rv-d1">{{basics.title}}</p>

                <div class="hero-contact rv rv-d2">
                    {{#if basics.email}}
                    <a href="mailto:{{basics.email}}">
                        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
                        {{basics.email}}
                    </a>
                    {{/if}}
                    {{#if basics.phone}}
                    <a href="tel:{{basics.phone}}">
                        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/></svg>
                        {{basics.phone}}
                    </a>
                    {{/if}}
                    {{#if basics.linkedin}}
                    <a href="{{basics.linkedin}}" target="_blank" rel="noopener">
                        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"/></svg>
                        LinkedIn
                    </a>
                    {{/if}}
                    {{#if basics.github}}
                    <a href="{{basics.github}}" target="_blank" rel="noopener">
                        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"/></svg>
                        GitHub
                    </a>
                    {{/if}}
                    {{#if basics.website}}
                    <a href="{{basics.website}}" target="_blank" rel="noopener">
                        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418"/></svg>
                        Website
                    </a>
                    {{/if}}
                </div>

                {{#if metrics}}
                <div class="hero-metrics rv rv-d3">
                    {{#each metrics}}
                    <div class="metric">
                        <div class="metric-val">{{this.value}}</div>
                        <div class="metric-label">{{this.label}}</div>
                    </div>
                    {{/each}}
                </div>
                {{/if}}
            </div>

            <div class="hero-portrait-wrap rv rv-d2">
                <div class="hero-portrait">
                    {{#if basics.photoUrl}}
                    <img src="{{basics.photoUrl}}" alt="{{basics.fullName}}" style="width:100%;height:100%;object-fit:cover;">
                    {{else}}
                    <div class="hero-portrait-ph">
                        <svg fill="none" viewBox="0 0 24 24" stroke-width="0.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
                    </div>
                    {{/if}}
                    <div class="hero-portrait-tag">{{#if basics.photoUrl}}{{basics.fullName}}{{else}}Professional Photo{{/if}}</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 2. CREDENTIALS BAR -->
{{#if certifications}}
{{#unless (isHidden "credentials")}}
<section class="credentials" id="credentials">
    <div class="container">
        <div class="credentials-strip rv">
            {{#each certifications}}
            <div class="cred-badge">
                <div class="cred-acronym">{{this.name}}</div>
                <div class="cred-issuer">{{this.issuer}}</div>
            </div>
            {{/each}}
        </div>
    </div>
</section>
{{/unless}}
{{/if}}

<!-- 3. VALUE PROPOSITION -->
{{#if basics.valueProposition}}
{{#unless (isHidden "value-proposition")}}
<section class="section value-prop">
